# ============================================================
# .env.example — LectureLive 完整环境变量配置
# 复制为 .env.local 后填入实际值
# ============================================================

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=http://localhost:3001
NODE_ENV=development

# === Auth ===
# 生产环境请使用: openssl rand -hex 32 生成强随机密钥
JWT_SECRET=change-me-to-a-strong-random-secret-min-32-chars
ENCRYPTION_KEY=change-me-to-a-different-strong-random-secret-min-32-chars
# 密钥轮换时可临时保留旧值，运行 npm run security:reencrypt-llm-keys 后再删除
# ENCRYPTION_KEY_PREVIOUS=old-encryption-key-for-rotation-only

# === Database (MySQL) ===
# 本地开发:
DATABASE_URL=mysql://lecturelive:your_password@localhost:3306/lecturelive
# 启动应用时自动执行 prisma db push，同步表结构到 MySQL
# 设为 false 可关闭自动建表
AUTO_DB_PUSH=true
# === Docker Compose 部署密码（在 .env 文件中设置） ===
# DB_PASSWORD=<使用 openssl rand -base64 24 生成>
# DB_PASSWORD_ENCODED=<同上但 URL 编码特殊字符>
# MYSQL_ROOT_PASSWORD=<使用 openssl rand -base64 24 生成>

# === Redis ===
# 本地开发:
REDIS_URL=redis://localhost:6379
# Docker Compose 部署（带密码）:
# REDIS_URL=redis://:your_redis_password@redis:6379
# REDIS_PASSWORD=<使用 openssl rand -base64 24 生成>

# === Soniox ASR ===
# Soniox API Key 推荐通过管理界面写入数据库（加密存储）
# 环境变量仅作为 fallback，优先级高于数据库：
# SONIOX_API_KEY=your_soniox_api_key
# SONIOX_US_API_KEY=your_us_key
# SONIOX_EU_API_KEY=your_eu_key
# SONIOX_JP_API_KEY=your_jp_key
SONIOX_DEFAULT_REGION=eu

# === Cloudreve V4 OAuth Storage ===
# 在 Cloudreve V4 管理面板中创建 OAuth 应用后获取以下凭据
# CLOUDREVE_BASE_URL=https://cloud.example.com
# CLOUDREVE_CLIENT_ID=your_oauth_client_id
# CLOUDREVE_CLIENT_SECRET=your_oauth_client_secret
# 允许连接到内网地址（开发环境使用）
# CLOUDREVE_ALLOW_PRIVATE_HOST=true

# === LLM Provider Configuration ===
# LLM 配置推荐通过管理界面写入数据库（API Key 加密存储）
# 以下仅作为数据库不可用时的 fallback：
# LLM_ACTIVE_PROVIDER=claude
# LLM_PROVIDERS_CLAUDE_NAME=claude
# LLM_PROVIDERS_CLAUDE_DISPLAY_NAME=Claude Sonnet
# LLM_PROVIDERS_CLAUDE_API_BASE=https://api.anthropic.com
# LLM_PROVIDERS_CLAUDE_API_KEY=sk-ant-xxxxx
# LLM_PROVIDERS_CLAUDE_MODEL=claude-sonnet-4-20250514
# LLM_PROVIDERS_CLAUDE_THINKING_BUDGET=0
# LLM_PROVIDERS_CLAUDE_MAX_TOKENS=4096
# LLM_PROVIDERS_CLAUDE_TEMPERATURE=0.3
# LLM_PROVIDERS_CLAUDE_IS_ANTHROPIC=true

# === Keyword Weights (可选) ===
# KEYWORD_WEIGHT_FOLDER=0.4
# KEYWORD_WEIGHT_SESSION_LLM=0.3
# KEYWORD_WEIGHT_UPLOADED_FILE=0.3

# === Proxy / IP ===
# 部署在 nginx/Cloudflare 等反向代理后面时设为 true，
# 这样限流才能从 X-Forwarded-For / X-Real-IP 读到真实客户端 IP
# 不设或 false 时，限流 key 统一为 'unknown'（所有人共用一个桶）
TRUSTED_PROXY=true

# === Default Language ===
NEXT_PUBLIC_DEFAULT_SOURCE_LANG=en
NEXT_PUBLIC_DEFAULT_TARGET_LANG=zh
