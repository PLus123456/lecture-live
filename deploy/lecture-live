show_help() {
    echo ""
    echo -e "${BOLD}LectureLive 管理工具 v${VERSION}${NC}"
    echo ""
    echo "用法: lecture-live [命令] [选项]"
    echo ""
    echo "  不带参数运行将进入交互式菜单"
    echo ""
    echo "命令:"
    echo "  start              启动所有服务"
    echo "  stop               停止所有服务"
    echo "  restart             重启所有服务"
    echo "  status              查看服务状态"
    echo "  log [web|ws] [-f]  查看日志 (-f 实时跟踪)"
    echo "  update              从 GitHub 更新到最新版"
    echo "  install             全新安装系统"
    echo "  uninstall           卸载系统（保留数据）"
    echo "  rollback            回滚到之前的版本"
    echo "  env                 查看环境配置（脱敏）"
    echo "  env edit            编辑环境配置"
    echo "  self-install        将此脚本安装到 /usr/local/bin"
    echo "  help                显示此帮助信息"
    echo ""
    echo "示例:"
    echo "  sudo lecture-live start        # 启动服务"
    echo "  sudo lecture-live restart      # 重启服务"
    echo "  lecture-live status             # 查看状态"
    echo "  lecture-live log -f             # 实时日志"
    echo "  lecture-live log web -n 100     # 查看 Web 最近 100 行日志"
    echo "  sudo lecture-live update       # 更新系统"
    echo ""
}

# ══════════════════════════════════════════
#  入口
# ══════════════════════════════════════════

main() {
    # 无参数：交互式菜单
    if [[ $# -eq 0 ]]; then
        run_interactive
        return
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        start)        cmd_start "$@" ;;
        stop)         cmd_stop "$@" ;;
        restart)      cmd_restart "$@" ;;
        status)       cmd_status "$@" ;;
        log|logs)     cmd_log "$@" ;;
        update|upgrade) cmd_update "$@" ;;
        install)      cmd_install "$@" ;;
        uninstall)    cmd_uninstall "$@" ;;
        rollback)     cmd_rollback "$@" ;;
        env)          cmd_env "$@" ;;
        self-install) cmd_self_install "$@" ;;
        help|-h|--help) show_help ;;
        version|-v|--version) echo "lecture-live v${VERSION}" ;;
        *)
            error "未知命令: $cmd"
            echo "  运行 lecture-live help 查看可用命令"
            exit 1
            ;;
    esac
}

main "$@"
