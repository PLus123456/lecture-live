{
  "name": "lecture-live",
  "version": "0.2.0",
  "private": true,
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "db:ensure": "node scripts/ensure-database.mjs",
    "dev": "next dev",
    "dev:ws": "ts-node server/websocket.ts",
    "prebuild": "prisma generate",
    "build": "next build",
    "build:ws": "esbuild server/websocket.ts --bundle --platform=node --target=node24 --outfile=dist/websocket.js --external:@prisma/client --external:socket.io --external:ioredis --external:jsonwebtoken --external:bcryptjs --alias:server-only=./deploy/shims/server-only.js",
    "prestart": "node scripts/ensure-database.mjs",
    "start": "next start",
    "prestart:ws": "node scripts/ensure-database.mjs",
    "start:ws": "ts-node server/websocket.ts",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:backfill-conversation-user-id": "node scripts/backfill-conversation-user-id.mjs",
    "billing:reset-quotas": "node scripts/reset-monthly-quotas.mjs",
    "billing:reconcile": "node scripts/reconcile-transcription-usage.mjs",
    "billing:maintenance": "ts-node scripts/billing-maintenance.ts",
    "security:reencrypt-llm-keys": "node scripts/reencrypt-llm-provider-keys.mjs",
    "postinstall": "node scripts/patch-next-minify.mjs && prisma generate"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "@prisma/client": "^5.22.0",
    "@soniox/client": "^1.0.2",
    "bcryptjs": "^2.4.3",
    "docx": "^9.6.1",
    "dompurify": "^3.4.2",
    "fix-webm-duration": "^1.0.6",
    "gpt-tokenizer": "^3.4.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.8.0",
    "next": "15.5.18",
    "officeparser": "^7.0.3",
    "pdf-parse": "^1.1.1",
    "pino": "^9.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.18",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.14"
    }
  }
}
