// prisma/schema.prisma

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  PRO
  FREE
}

enum SessionStatus {
  CREATED       // 刚创建，未开始录音
  RECORDING     // 录音中
  PAUSED        // 暂停
  FINALIZING    // 正在结束
  COMPLETED     // 已完成，文件已保存
  ARCHIVED      // 归档
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  displayName         String
  avatarPath          String?                     // 头像路径
  role                UserRole  @default(FREE)
  status              Int       @default(1)       // 用户状态：1=正常, 0=禁用
  points              Int       @default(0)       // 积分
  originalRole        UserRole?                   // 原始用户组（购买到期后回退至此）
  roleExpiresAt       DateTime?                   // 用户组过期日期，null=永久有效
  tokenVersion        Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // 配额
  transcriptionMinutesUsed    Int     @default(0)
  transcriptionMinutesLimit   Int     @default(60)     // FREE=60min/月, PRO=600, ADMIN=unlimited
  quotaResetAt                DateTime?
  storageHoursUsed            Float   @default(0)
  storageHoursLimit           Float   @default(10)     // FREE=10h录音, PRO=100h, ADMIN=unlimited
  storageBytesUsed            BigInt  @default(0)             // chat 上传文件累计字节
  storageBytesLimit           BigInt  @default(104857600)     // FREE 默认 100MB；admin 可调（PRO/ADMIN 通过 SiteSetting 配置）
  allowedModels               String  @default("local") // 逗号分隔: "local,gpt,claude,deepseek"
  customGroupId               String?                      // 自定义用户组 ID，指向 SiteSetting 中存储的自定义组

  sessions    Session[]
  shareLinks  ShareLink[]
}

model Session {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  title           String
  titleEn         String?                           // AI 生成的英文标题
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  durationMs      Int       @default(0)
  status          SessionStatus @default(CREATED)
  serverStartedAt DateTime?
  serverPausedMs  Int       @default(0)
  serverPausedAt  DateTime?
  finalizeLockedAt DateTime?
  // B7：本会话转录分钟被扣费的时刻（realtime/异步上传/完整版 finalize 时置）。对账按此归期，
  // 而非 createdAt —— 跨月/延迟收尾/自动回收的会话，扣费落在 finalize 时的配额窗口，用 createdAt
  // 归期会把它算错周期、虚报 drift。与 InterpretUsage.chargedAt 同一"按扣费时刻归期"口径。
  // 多笔扣费(realtime + 完整版补全)时为最后一笔的时刻(last-write)；同周期常态无碍。
  billedAt        DateTime?

  // v2.1: 音频源 & 区域
  audioSource     String    @default("microphone")  // "microphone" | "system_audio"
  sonioxRegion    String    @default("auto")        // "us" | "eu" | "jp" | "auto"

  // Cloudreve 存储路径
  recordingPath   String?   // e.g., "/{userId}/recordings/{sessionId}.webm"
  transcriptPath  String?   // e.g., "/{userId}/transcripts/{sessionId}.json"
  summaryPath     String?   // e.g., "/{userId}/summaries/{sessionId}.json"
  reportPath      String?   // e.g., "/{userId}/reports/{sessionId}.json"

  // 翻译模式
  translationMode String    @default("soniox")     // "soniox" | "local" | "both"

  // 元数据
  courseName      String?
  sourceLang      String    @default("en")
  targetLang      String    @default("zh")
  llmProvider     String    @default("claude")

  // Soniox async file transcription
  // 文件上传转录的进度跟踪。null = 未走 async 路径（实时录音 or 浏览器 realtime 文件转录）
  // 状态机：uploading_chunks → transcoding → uploading_to_soniox → transcribing → completed / failed
  sonioxFileId             String?
  sonioxTranscriptionId    String?
  asyncTranscribeStatus    String?
  asyncTranscribeError     String?   @db.Text
  asyncTranscribeStartedAt DateTime?
  // B1：异步上传转录入口的原子配额预留分钟。init 预留成功后写入（同时已计入
  // transcriptionMinutesUsed）；finalize 时转为实扣（release 预留 + deduct 实际）、
  // cancel/删会话/失败回收时释放。非 0 即表示有一笔在途预留待结算——cron 会兜底释放
  // 终态(failed/canceled/completed) 却仍残留预留的会话，防漏释放导致额度泄漏。
  asyncReservedMinutes     Int       @default(0)

  // 完整版补全转录：对已录制会话的完整音频（含断网续采段）重跑一次 Soniox 异步文件转录，
  // 产出一份「独立并列」的完整转录（不覆盖实时 transcriptPath）。与上述 async-upload 状态机
  // 完全分离，各自独立字段，避免 reclaimStaleAsyncUploads 等误处理。
  // 状态机：pending → transcoding → transcribing → finalizing → completed / failed
  fullTranscriptPath        String?   // e.g., "/{userId}/full-transcripts/{sessionId}.json"
  fullTranscribeStatus      String?
  fullTranscribeError       String?   @db.Text
  fullTranscribeStartedAt   DateTime?
  fullSonioxFileId          String?
  fullSonioxTranscriptionId String?
  // R4：完整版补全转录入口的原子配额预留分钟（与 B1 的 asyncReservedMinutes 平行）。
  // 触发时预留成功后写入（同时已计入 transcriptionMinutesUsed）；finalize 时转为实扣
  //（settleFullReservation 释放预留 + deduct 实际）、删会话/失败回收时释放。非 0 即表示有一笔
  // 在途预留待结算——cron releaseOrphanFullReservations 兜底释放终态(completed/failed)却仍残留的会话。
  fullReservedMinutes       Int       @default(0)

  // 录音音频增强（后处理）：录音结束后送外部 worker 做响度归一化 + 降噪，产出一份
  // 「并列」的增强版音频（不覆盖 recordingPath），回放时可在原始/增强间切换。
  // 状态机：pending → processing → completed / failed；任务真源在 JobQueue(type=audio_enhance)，
  // 这里的状态仅供回放页/列表快速展示。
  enhancedAudioPath   String?   // e.g., "/{userId}/recordings/{sessionId}-{stamp}.mp4" 或 local: 引用
  audioEnhanceStatus  String?
  audioEnhanceError   String?   @db.Text

  shareLinks      ShareLink[]
  folders         FolderSession[]
  conversations   Conversation[]
  conversationSessions  ConversationSession[]

  @@index([userId])
  @@index([asyncTranscribeStatus])
  @@index([fullTranscribeStatus])
  @@index([audioEnhanceStatus])
}

model Folder {
  id          String    @id @default(cuid())
  userId      String
  name        String
  parentId    String?
  parent      Folder?   @relation("FolderTree", fields: [parentId], references: [id])
  children    Folder[]  @relation("FolderTree")
  sessions    FolderSession[]
  keywordPool FolderKeyword[]
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([parentId])
}

model FolderKeyword {
  id          String   @id @default(cuid())
  folderId    String
  folder      Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  keyword     String
  source      String   // "auto:{sessionId}" | "manual" | "file:{fileName}"
  confidence  Float    @default(1.0)   // LLM 给的重要度评分 0-1
  usageCount  Int      @default(0)     // 被多少个 session 使用过
  createdAt   DateTime @default(now())

  @@unique([folderId, keyword]) // 同文件夹内不重复
  @@index([folderId])
}

model FolderSession {
  folderId  String
  folder    Folder  @relation(fields: [folderId], references: [id])
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  @@id([folderId, sessionId])
  @@index([sessionId])
}

model ShareLink {
  id          String    @id @default(cuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id])
  createdBy   String
  creator     User      @relation(fields: [createdBy], references: [id])
  token       String    @unique @default(cuid())  // 分享链接 token
  isLive      Boolean   @default(false)            // 是否实时分享
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([sessionId])
  @@index([createdBy])
}

// ─── 审计日志 ───
model AuditLog {
  id        String   @id @default(cuid())
  action    String                           // 操作类型，如 "user.login", "admin.settings.update"
  detail    String?  @db.Text               // 操作详情（JSON 或纯文本）
  userId    String?                          // 操作者用户 ID（系统事件无用户）
  userName  String?                          // 操作者显示名称（冗余存储，用户删除后仍可显示）
  ip        String?                          // 客户端 IP 地址
  createdAt DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

// ─── 对账运行记录 ───
model ReconciliationRun {
  id              String   @id @default(cuid())
  triggeredBy     String                          // 触发者用户 ID
  triggeredByName String?                         // 触发者显示名称
  status          String   @default("running")    // "running" | "completed" | "failed"
  totalUsers      Int      @default(0)
  mismatchCount   Int      @default(0)
  fixedCount      Int      @default(0)
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  mismatches      ReconciliationMismatch[]

  @@index([createdAt])
}

// ─── 对账差异明细 ───
model ReconciliationMismatch {
  id              String   @id @default(cuid())
  runId           String
  run             ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  userId          String
  userEmail       String
  recordedMinutes Int                              // 从 session 计算的实际用量
  storedMinutes   Int                              // user.transcriptionMinutesUsed 的值
  driftMinutes    Int                              // recordedMinutes - storedMinutes
  fixed           Boolean  @default(false)
  fixedAt         DateTime?
  fixedBy         String?                          // 修复者用户 ID

  @@index([runId])
  @@index([userId])
}

// ─── 同声传译用量台账（每次 /api/interpret/deduct 成功扣费记一笔） ───
// interpret 扣费直接 increment User.transcriptionMinutesUsed，但不产生任何 Session 行；
// 对账（reconcileTranscriptionUsage）仅按 COMPLETED Session 重算，会对用过同传的用户虚报负向
// drift。此表把每次已扣的 interpret 分钟持久化，让对账把 interpret 用量计入 expected，消除虚报。
// billedMinutes 与 deduct 侧实扣分钟一字一致（getBillableMinutes(effectiveMs)）。
// 与 ChatAttachment.userId / Conversation.userId 同规约：userId 为冗余列、不建 User relation
//（避免 User 反向关系膨胀）。台账只增不减；deduct 已是一次性锚点消费，天然不重复。
model InterpretUsage {
  id            String   @id @default(cuid())
  userId        String                              // 冗余列，不建 relation，便于按用户+周期聚合
  billedMinutes Int                                 // 本次实扣分钟，口径与 deduct 一字一致
  durationMs    Int?                                // 本次计费时长（effectiveMs），审计参考
  chargedAt     DateTime @default(now())            // 扣费时刻，对账按 quotaResetAt 周期窗口截断

  @@index([userId, chargedAt])
}

// B3：同声传译的服务端持久化会话。interpret 是浏览器直连 Soniox，服务端只在 /start 与 /deduct
// 观测；旧实现若客户端不调 /deduct（改装/掉线/故意）则整场免费、无任何兜底。此表在 /start 落一行
// (settledAt=null=未结算)，/deduct 成功扣费时**原子认领**它(settledAt 置非空)，cron 对超时仍未结算
// 的会话按服务端墙钟(startedAt→now，封顶 MAX_INTERPRET_DURATION)兜底扣费并结算。deduct 与 cron 经
// settledAt 的条件原子认领互斥 → 每场恰好扣一次，杜绝「不调 deduct 白嫖」与「deduct+cron 双扣」。
model InterpretSession {
  id            String    @id @default(cuid())
  userId        String                              // 冗余列，便于 cron 扫描 + 按用户结算
  anchorId      String?                             // /start 建立的 Redis 锚点 id，供 deduct 精确认领
  startedAt     DateTime  @default(now())           // 服务端会话开始时刻（cron 兜底计费的权威墙钟起点）
  settledAt     DateTime?                            // 非空=已结算(deduct 或 cron)；认领闸门
  billedMinutes Int?                                // 结算实扣分钟（审计）
  settledBy     String?                             // 'deduct' | 'cron_reclaim'（审计）

  @@index([settledAt, startedAt])
  @@index([userId, settledAt])
  @@index([anchorId])
}

// ─── 站点设置（Key-Value 存储） ───
model SiteSetting {
  key       String   @id          // 如 "site_name", "site_url", "logo_path" 等
  value     String   @db.Text     // JSON 或纯文本值
  updatedAt DateTime @updatedAt
}

// ─── LLM 供应商（网关）配置 ───
model LlmProvider {
  id             String             @id @default(cuid())
  name           String                           // 显示名称，如 "OpenAI 主力"
  apiKey         String             @db.Text      // API 密钥
  apiBase        String                           // API 地址，如 "https://api.openai.com"
  isAnthropic    Boolean            @default(false) // 是否使用 Anthropic 原生 API
  sortOrder      Int                @default(0)   // 排序
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  models         LlmModel[]
  registryModels LlmRegistryModel[]
}

// ─── LLM 模型库（网关下登记的模型规格；「用哪个模型做什么、怎么调参」在 LlmModel 路由行上） ───
// 规格类字段（上下文/最大输出/输入能力）的唯一真源。admin 保存注册模型时把规格写穿到
// 其下所有路由行（LlmModel），gateway 运行时仍只读路由行 —— 保证旧 id 引用与解析逻辑零变化。
model LlmRegistryModel {
  id            String      @id @default(cuid())
  providerId    String
  provider      LlmProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  modelId       String                          // 模型标识，如 "gpt-4o", "doubao-seed-2-0-pro"
  displayName   String                          // 显示名称
  kind          String      @default("TEXT")    // "TEXT" | "EMBEDDING"（嵌入模型无思考/温度参数）
  supportsImage Boolean     @default(false)     // 是否接受图片输入（多模态）
  maxTokens     Int         @default(4096)      // 单次输出 max_tokens
  contextWindow Int         @default(8192)      // 输入上下文窗口（token）
  embeddingDimensions Int?                      // 嵌入向量维度（仅 kind=EMBEDDING，展示用）
  // 连通性验证（admin 面板「验证」按钮写入）
  status        String      @default("UNVERIFIED") // "UNVERIFIED" | "OK" | "FAILED"
  lastCheckedAt DateTime?
  lastError     String?     @db.Text
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  routes        LlmModel[]

  @@index([providerId])
}

// ─── LLM 用途枚举 ───
enum LlmPurpose {
  CHAT                // 对话
  REALTIME_SUMMARY    // 实时摘要
  FINAL_SUMMARY       // 最终摘要
  KEYWORD_EXTRACTION  // 关键词提取
  EMBEDDING           // 嵌入向量（用于 chat L6 RAG 检索）
}

// ─── LLM 用途路由行（用途 × 模型，一行一个绑定） ───
// 历史上这张表叫「模型配置」，每个 (模型, 用途) 一行、参数全在行上。模型库拆出后语义收窄为
// 「路由行」：purpose/isDefault/thinkingMode/thinkingDepth/temperature 是路由层参数（同一模型
// 在不同用途可配不同思考与温度）；modelId/displayName/supportsImage/maxTokens/contextWindow
// 保留为 registry 的写穿副本（gateway/客户端继续读这里，旧部署未迁移时也能独立工作）。
model LlmModel {
  id            String      @id @default(cuid())
  providerId    String
  provider      LlmProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  // 所属模型库条目；空 = 尚未迁移的历史行（ensureLlmRegistry 会补建并回填）。
  // 删除模型库条目级联删除其所有路由行。
  registryId    String?
  registry      LlmRegistryModel? @relation(fields: [registryId], references: [id], onDelete: Cascade)
  modelId       String                          // 模型标识，如 "gpt-4o", "claude-sonnet-4-6"
  displayName   String                          // 显示名称
  // 思考能力控制（路由层参数，按用途独立）：
  //  thinkingMode:
  //    NONE   - 不思考（请求不带 thinking/reasoning 参数）
  //    AUTO   - 模型自己决定是否思考，请求不带任何 thinking/reasoning 参数（GLM-4.5/DeepSeek-V3 等）
  //    FORCED - 强制思考（o-series/R1 自带；Anthropic 按 thinkingDepth 强制启用）
  //    DEPTH  - 带深度思考（Claude Extended Thinking、reasoning_effort）；允许用户选 off/low/medium/high
  //  supportsThinkingDepth - DEPRECATED：被 thinkingMode='DEPTH' 取代，保留字段用于向后兼容
  //  thinkingDepth - 默认深度（DEPTH 模式下作为 fallback；FORCED 模式下作为强制思考的深度）
  thinkingMode          String  @default("NONE")     // "NONE" | "AUTO" | "FORCED" | "DEPTH"
  supportsThinkingDepth Boolean @default(false)
  thinkingDepth         String  @default("medium")   // "low" | "medium" | "high"
  // ↓ 规格字段：registry 的写穿副本（admin 改模型库时同步），运行时读取处保持不变
  supportsImage Boolean @default(false)
  maxTokens     Int         @default(4096)      // 单次输出 max_tokens（传给 API 的 max_tokens 字段）
  contextWindow Int         @default(8192)      // 模型输入上下文窗口大小（token），用于 LectureLive 内部预算/降级判断
  temperature   Float       @default(0.3)       // 路由层参数：该用途下的采样温度
  purpose       LlmPurpose  @default(CHAT)      // 用途
  isDefault     Boolean     @default(false)      // 该用途下的默认模型
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([providerId])
  @@index([purpose])
  @@index([registryId])
}

// ─── 后台任务队列 ───
model JobQueue {
  id            String    @id @default(cuid())
  type          String                            // keyword_extraction, report_generation, quota_reset, stale_session_reclaim, reconciliation, storage_cleanup, storage_migration, billing_maintenance
  status        String    @default("SUBMITTED")   // SUBMITTED | PENDING | PROCESSING | SUCCESS | FAILED
  params        String?   @db.Text                // JSON 格式的任务参数
  result        String?   @db.Text                // JSON 格式的结果摘要
  error         String?   @db.Text                // 失败时的错误信息
  sessionId     String?                           // 关联的会话 ID
  userId        String?                           // 关联的用户 ID
  triggeredBy   String?                           // "system" | "admin:{userId}"
  attempt       Int       @default(1)             // 当前尝试次数
  maxAttempts   Int       @default(1)             // 最大重试次数
  createdAt     DateTime  @default(now())
  startedAt     DateTime?                         // 开始处理时间
  completedAt   DateTime?                         // 处理完成时间

  @@index([type])
  @@index([status])
  @@index([sessionId])
  @@index([createdAt])
  @@index([userId])
  @@index([userId, status])
}

// ─── Chat 对话历史（每次录音可有多个 Conversation，"新建对话"即关闭旧的开新的） ───
model Conversation {
  id          String                @id @default(cuid())
  sessionId   String?
  session     Session?              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // 对话归属用户。创建时由服务端写入（不再靠录音反推）。
  // 可空仅为兼容历史"零录音纯 global 对话"（无任何反推材料的孤儿，回填后仍为 NULL）；
  // 代码侧把 NULL 当"无主"——列表不显示、访问一律 404。新建对话恒带 userId，实质非空。
  // 与 ChatAttachment.userId 同规约：纯冗余列，不建 relation（避免 User 反向关系膨胀）。
  userId      String?
  title       String?                                  // AI 生成的对话标题（首条用户消息提取，可为空）
  startedAt   DateTime              @default(now())
  endedAt     DateTime?                                // null = 当前活跃；非 null = 已关闭，只读
  // 单次对话内的降级状态（单调下降，只能 ≥ 上次记录的值）
  degradationLevel Int              @default(1)        // 1..7，对应 7 级降级链
  // 用户主动归档。关闭(endedAt 非空)≠归档：关闭只是只读但仍在主列表；archived=从主列表隐藏，进历史页归档区。
  archived    Boolean              @default(false)
  messages    ConversationMessage[]
  attachments  ChatAttachment[]
  sessions    ConversationSession[]

  @@index([sessionId, startedAt])
  @@index([userId])
}

model ConversationSession {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sessionId      String
  session        Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  addedAt        DateTime     @default(now())

  @@id([conversationId, sessionId])
  @@index([sessionId])
}

model ConversationMessage {
  id               String        @id @default(cuid())
  conversationId   String
  conversation     Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role             String                              // 'user' | 'assistant' | 'system'
  content          String        @db.Text
  // 发这条消息时 transcript 已录到的偏移（毫秒），用于"时间锚点 system 消息"对齐
  transcriptOffsetMs Int?
  // 本轮命中的降级级别（仅 assistant 消息有意义）
  degradationLevel Int?
  // token 用量（仅 assistant 消息）
  inputTokens      Int?
  outputTokens     Int?
  // 全局单调自增序号 —— 稳定排序键，替代 createdAt 排序定位压缩切割点（同毫秒时间戳下
  // user/assistant/system 顺序可能错乱）。全局自增即蕴含"对话内单调"；DB 赋值、写入点无需赋值。
  // @unique 既满足 MySQL"自增列须为键"，又给 orderBy seq 提供索引。
  seq              BigInt        @unique @default(autoincrement())
  createdAt        DateTime      @default(now())

  @@index([conversationId, seq])
}

// ─── Chat 附件（图片 / 文档 / 文本），持久化到 Cloudreve；每条与 Conversation 多对一 ───
model ChatAttachment {
  id                String        @id @default(cuid())
  conversationId    String
  conversation      Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId            String                                      // 冗余存储便于 admin 按用户清理 + 配额复核
  kind              String                                      // 'image' | 'document' | 'text'
  fileName          String                                      // 上传时的原始文件名（已 sanitize）
  mimeType          String
  bytes             BigInt                                      // 文件大小，配额扣减依据
  cloudrevePath     String                                      // /{userId}/chat-uploads/{conversationId}/{filename}
  extractedTextPath String?                                     // 仅 document 类，抽取出的 .txt 在 Cloudreve 的路径
  createdAt         DateTime      @default(now())
  lastAccessedAt    DateTime      @default(now())               // 用于 LRU 清理

  @@index([conversationId])
  @@index([userId])
  @@index([createdAt])
  @@index([userId, lastAccessedAt])
}
