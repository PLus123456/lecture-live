// prisma/schema.prisma

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  PRO
  FREE
}

enum SessionStatus {
  CREATED       // 刚创建，未开始录音
  RECORDING     // 录音中
  PAUSED        // 暂停
  FINALIZING    // 正在结束
  COMPLETED     // 已完成，文件已保存
  ARCHIVED      // 归档
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  displayName         String
  avatarPath          String?                     // 头像路径
  role                UserRole  @default(FREE)
  status              Int       @default(1)       // 用户状态：1=正常, 0=禁用
  points              Int       @default(0)       // 积分
  originalRole        UserRole?                   // 原始用户组（购买到期后回退至此）
  roleExpiresAt       DateTime?                   // 用户组过期日期，null=永久有效
  tokenVersion        Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // 配额
  transcriptionMinutesUsed    Int     @default(0)
  transcriptionMinutesLimit   Int     @default(60)     // FREE=60min/月, PRO=600, ADMIN=unlimited
  quotaResetAt                DateTime?
  storageHoursUsed            Float   @default(0)
  storageHoursLimit           Float   @default(10)     // FREE=10h录音, PRO=100h, ADMIN=unlimited
  storageBytesUsed            BigInt  @default(0)             // chat 上传文件累计字节
  storageBytesLimit           BigInt  @default(104857600)     // FREE 默认 100MB；admin 可调（PRO/ADMIN 通过 SiteSetting 配置）
  allowedModels               String  @default("local") // 逗号分隔: "local,gpt,claude,deepseek"
  customGroupId               String?                      // 自定义用户组 ID，指向 SiteSetting 中存储的自定义组

  sessions    Session[]
  shareLinks  ShareLink[]
}

model Session {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  title           String
  titleEn         String?                           // AI 生成的英文标题
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  durationMs      Int       @default(0)
  status          SessionStatus @default(CREATED)
  serverStartedAt DateTime?
  serverPausedMs  Int       @default(0)
  serverPausedAt  DateTime?
  finalizeLockedAt DateTime?

  // v2.1: 音频源 & 区域
  audioSource     String    @default("microphone")  // "microphone" | "system_audio"
  sonioxRegion    String    @default("auto")        // "us" | "eu" | "jp" | "auto"

  // Cloudreve 存储路径
  recordingPath   String?   // e.g., "/{userId}/recordings/{sessionId}.webm"
  transcriptPath  String?   // e.g., "/{userId}/transcripts/{sessionId}.json"
  summaryPath     String?   // e.g., "/{userId}/summaries/{sessionId}.json"
  reportPath      String?   // e.g., "/{userId}/reports/{sessionId}.json"

  // 翻译模式
  translationMode String    @default("soniox")     // "soniox" | "local" | "both"

  // 元数据
  courseName      String?
  sourceLang      String    @default("en")
  targetLang      String    @default("zh")
  llmProvider     String    @default("claude")

  // Soniox async file transcription
  // 文件上传转录的进度跟踪。null = 未走 async 路径（实时录音 or 浏览器 realtime 文件转录）
  // 状态机：uploading_chunks → transcoding → uploading_to_soniox → transcribing → completed / failed
  sonioxFileId             String?
  sonioxTranscriptionId    String?
  asyncTranscribeStatus    String?
  asyncTranscribeError     String?   @db.Text
  asyncTranscribeStartedAt DateTime?

  shareLinks      ShareLink[]
  folders         FolderSession[]
  conversations   Conversation[]
  conversationSessions  ConversationSession[]

  @@index([userId])
  @@index([asyncTranscribeStatus])
}

model Folder {
  id          String    @id @default(cuid())
  userId      String
  name        String
  parentId    String?
  parent      Folder?   @relation("FolderTree", fields: [parentId], references: [id])
  children    Folder[]  @relation("FolderTree")
  sessions    FolderSession[]
  keywordPool FolderKeyword[]
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([parentId])
}

model FolderKeyword {
  id          String   @id @default(cuid())
  folderId    String
  folder      Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  keyword     String
  source      String   // "auto:{sessionId}" | "manual" | "file:{fileName}"
  confidence  Float    @default(1.0)   // LLM 给的重要度评分 0-1
  usageCount  Int      @default(0)     // 被多少个 session 使用过
  createdAt   DateTime @default(now())

  @@unique([folderId, keyword]) // 同文件夹内不重复
  @@index([folderId])
}

model FolderSession {
  folderId  String
  folder    Folder  @relation(fields: [folderId], references: [id])
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  @@id([folderId, sessionId])
  @@index([sessionId])
}

model ShareLink {
  id          String    @id @default(cuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id])
  createdBy   String
  creator     User      @relation(fields: [createdBy], references: [id])
  token       String    @unique @default(cuid())  // 分享链接 token
  isLive      Boolean   @default(false)            // 是否实时分享
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([sessionId])
  @@index([createdBy])
}

// ─── 审计日志 ───
model AuditLog {
  id        String   @id @default(cuid())
  action    String                           // 操作类型，如 "user.login", "admin.settings.update"
  detail    String?  @db.Text               // 操作详情（JSON 或纯文本）
  userId    String?                          // 操作者用户 ID（系统事件无用户）
  userName  String?                          // 操作者显示名称（冗余存储，用户删除后仍可显示）
  ip        String?                          // 客户端 IP 地址
  createdAt DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

// ─── 对账运行记录 ───
model ReconciliationRun {
  id              String   @id @default(cuid())
  triggeredBy     String                          // 触发者用户 ID
  triggeredByName String?                         // 触发者显示名称
  status          String   @default("running")    // "running" | "completed" | "failed"
  totalUsers      Int      @default(0)
  mismatchCount   Int      @default(0)
  fixedCount      Int      @default(0)
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  mismatches      ReconciliationMismatch[]

  @@index([createdAt])
}

// ─── 对账差异明细 ───
model ReconciliationMismatch {
  id              String   @id @default(cuid())
  runId           String
  run             ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  userId          String
  userEmail       String
  recordedMinutes Int                              // 从 session 计算的实际用量
  storedMinutes   Int                              // user.transcriptionMinutesUsed 的值
  driftMinutes    Int                              // recordedMinutes - storedMinutes
  fixed           Boolean  @default(false)
  fixedAt         DateTime?
  fixedBy         String?                          // 修复者用户 ID

  @@index([runId])
  @@index([userId])
}

// ─── 站点设置（Key-Value 存储） ───
model SiteSetting {
  key       String   @id          // 如 "site_name", "site_url", "logo_path" 等
  value     String   @db.Text     // JSON 或纯文本值
  updatedAt DateTime @updatedAt
}

// ─── LLM 供应商配置 ───
model LlmProvider {
  id          String     @id @default(cuid())
  name        String                           // 显示名称，如 "OpenAI 主力"
  apiKey      String     @db.Text              // API 密钥
  apiBase     String                           // API 地址，如 "https://api.openai.com"
  isAnthropic Boolean    @default(false)       // 是否使用 Anthropic 原生 API
  sortOrder   Int        @default(0)           // 排序
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  models      LlmModel[]
}

// ─── LLM 模型配置（一个供应商可有多个模型） ───
enum LlmPurpose {
  CHAT                // 对话
  REALTIME_SUMMARY    // 实时摘要
  FINAL_SUMMARY       // 最终摘要
  KEYWORD_EXTRACTION  // 关键词提取
  EMBEDDING           // 嵌入向量（用于 chat L6 RAG 检索）
}

model LlmModel {
  id            String      @id @default(cuid())
  providerId    String
  provider      LlmProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  modelId       String                          // 模型标识，如 "gpt-4o", "claude-sonnet-4-6"
  displayName   String                          // 显示名称
  // 思考能力控制：
  //  thinkingMode:
  //    NONE   - 不支持思考（GPT-3.5、文本生成模型）
  //    AUTO   - 模型自己决定是否思考，请求不带任何 thinking/reasoning 参数（GLM-4.5/DeepSeek-V3 等）
  //    FORCED - 模型自带思考无法关闭（OpenAI o-series、DeepSeek R1）；UI 仍允许 auto/forced
  //    DEPTH  - 支持深度思考（Claude Extended Thinking、OpenAI gpt-5 系列 reasoning_effort）；
  //             允许用户选 off/low/medium/high
  //  supportsThinkingDepth - DEPRECATED：被 thinkingMode='DEPTH' 取代，保留字段用于向后兼容
  //  thinkingDepth - 默认深度（DEPTH 模式下作为 fallback；AUTO/FORCED 模式下作为请求的 effort 默认值）
  thinkingMode          String  @default("NONE")     // "NONE" | "AUTO" | "FORCED" | "DEPTH"
  supportsThinkingDepth Boolean @default(false)
  thinkingDepth         String  @default("medium")   // "low" | "medium" | "high"
  // 输入能力：是否接受图片输入（多模态）
  supportsImage Boolean @default(false)
  maxTokens     Int         @default(4096)      // 单次输出 max_tokens（传给 API 的 max_tokens 字段）
  contextWindow Int         @default(8192)      // 模型输入上下文窗口大小（token），用于 LectureLive 内部预算/降级判断
  temperature   Float       @default(0.3)
  purpose       LlmPurpose  @default(CHAT)      // 用途
  isDefault     Boolean     @default(false)      // 该用途下的默认模型
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([providerId])
  @@index([purpose])
}

// ─── 后台任务队列 ───
model JobQueue {
  id            String    @id @default(cuid())
  type          String                            // keyword_extraction, report_generation, quota_reset, stale_session_reclaim, reconciliation, storage_cleanup, storage_migration, billing_maintenance
  status        String    @default("SUBMITTED")   // SUBMITTED | PENDING | PROCESSING | SUCCESS | FAILED
  params        String?   @db.Text                // JSON 格式的任务参数
  result        String?   @db.Text                // JSON 格式的结果摘要
  error         String?   @db.Text                // 失败时的错误信息
  sessionId     String?                           // 关联的会话 ID
  userId        String?                           // 关联的用户 ID
  triggeredBy   String?                           // "system" | "admin:{userId}"
  attempt       Int       @default(1)             // 当前尝试次数
  maxAttempts   Int       @default(1)             // 最大重试次数
  createdAt     DateTime  @default(now())
  startedAt     DateTime?                         // 开始处理时间
  completedAt   DateTime?                         // 处理完成时间

  @@index([type])
  @@index([status])
  @@index([sessionId])
  @@index([createdAt])
  @@index([userId])
  @@index([userId, status])
}

// ─── Chat 对话历史（每次录音可有多个 Conversation，"新建对话"即关闭旧的开新的） ───
model Conversation {
  id          String                @id @default(cuid())
  sessionId   String?
  session     Session?              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title       String?                                  // AI 生成的对话标题（首条用户消息提取，可为空）
  startedAt   DateTime              @default(now())
  endedAt     DateTime?                                // null = 当前活跃；非 null = 已关闭，只读
  // 单次对话内的降级状态（单调下降，只能 ≥ 上次记录的值）
  degradationLevel Int              @default(1)        // 1..7，对应 7 级降级链
  messages    ConversationMessage[]
  attachments  ChatAttachment[]
  sessions    ConversationSession[]

  @@index([sessionId, startedAt])
}

model ConversationSession {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sessionId      String
  session        Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  addedAt        DateTime     @default(now())

  @@id([conversationId, sessionId])
  @@index([sessionId])
}

model ConversationMessage {
  id               String        @id @default(cuid())
  conversationId   String
  conversation     Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role             String                              // 'user' | 'assistant' | 'system'
  content          String        @db.Text
  // 发这条消息时 transcript 已录到的偏移（毫秒），用于"时间锚点 system 消息"对齐
  transcriptOffsetMs Int?
  // 本轮命中的降级级别（仅 assistant 消息有意义）
  degradationLevel Int?
  // token 用量（仅 assistant 消息）
  inputTokens      Int?
  outputTokens     Int?
  createdAt        DateTime      @default(now())

  @@index([conversationId, createdAt])
}

// ─── Chat 附件（图片 / 文档 / 文本），持久化到 Cloudreve；每条与 Conversation 多对一 ───
model ChatAttachment {
  id                String        @id @default(cuid())
  conversationId    String
  conversation      Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId            String                                      // 冗余存储便于 admin 按用户清理 + 配额复核
  kind              String                                      // 'image' | 'document' | 'text'
  fileName          String                                      // 上传时的原始文件名（已 sanitize）
  mimeType          String
  bytes             BigInt                                      // 文件大小，配额扣减依据
  cloudrevePath     String                                      // /{userId}/chat-uploads/{conversationId}/{filename}
  extractedTextPath String?                                     // 仅 document 类，抽取出的 .txt 在 Cloudreve 的路径
  createdAt         DateTime      @default(now())
  lastAccessedAt    DateTime      @default(now())               // 用于 LRU 清理

  @@index([conversationId])
  @@index([userId])
  @@index([createdAt])
  @@index([userId, lastAccessedAt])
}
